# gg-monitor runtime configuration
# Copy to .env and edit. Values here are defaults.

# Directory where dispatch queue locks are stored.
# MONITOR_QUEUE_DIR=.tmp/monitor-dispatch-queue

# Path for the structured NDJSON session log.
# When omitted, a timestamped file is auto-created under .tmp/.
# MONITOR_SESSION_LOG=.tmp/monitor-session.ndjson
